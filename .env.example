# 本番(Vercel)で設定する環境変数の見本。
# ローカル開発では未設定でOK（自動でローカルDB・認証バイパスになる）。

# --- Turso (データベース) ---
# Tursoでデータベースを作成すると取得できる
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Vercel Blob (写真保存) ---
# VercelでBlobストアを作成すると自動で設定される（手動入力不要な場合あり）
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# --- ログインパスワード ---
# このアプリにログインするためのパスワード（自分で決める）
APP_PASSWORD=好きなパスワードをここに
